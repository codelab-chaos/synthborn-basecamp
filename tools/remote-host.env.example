# Copy to remote-host.env at the REPO ROOT (gitignored):
#   cp tools/remote-host.env.example remote-host.env
#
# One file for all Synth* mods. Tools load: remote-host.env (root) → legacy per-mod files.
#
# Stable hostname: add to Windows hosts file (Admin Notepad):
#   192.168.0.128  macbook-server.org
# Then use macbook-server.org below instead of raw IPs. Pair with DHCP reservation on the router.
#
# Toggle: HYTALE_REMOTE_ENABLED=true|false  (or --local / --remote on any tool)

HYTALE_REMOTE_ENABLED=false

HYTALE_REMOTE_HOST=macbook-server.org
HYTALE_REMOTE_SSH=hytale-mac
HYTALE_REMOTE_USER=your-mac-username
HYTALE_REMOTE_SAVES="/Users/your-mac-username/Library/Application Support/Hytale/UserData/Saves"
HYTALE_REMOTE_REPO=~/git/hytale-mods
HYTALE_REMOTE_INSTALL="$HOME/Library/Application Support/Hytale/install/release/package"

# RCON + Terrascape HTTP from Windows (hostname from hosts file or LAN IP).
SYNTH_RCON_HOST=macbook-server.org

# Optional full URL override (default: http://SYNTH_RCON_HOST:5960 when remote is on)
# SYNTH_TERRASCAPE_URL=http://macbook-server.org:5960
