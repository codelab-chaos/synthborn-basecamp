{
  "name": "prefab-gallery",
  "version": "1.0.0",
  "private": true,
  "description": "React prefab gallery with voxel previews",
  "scripts": {
    "build:data": "node scripts/build-prefab-gallery.js ../../_Assets/Server/Prefabs",
    "build:web": "webpack --mode production",
    "build": "npm run build:data && npm run build:web",
    "dev": "webpack serve --mode development",
    "serve": "node scripts/serve-static.js ../../apps/prefab-gallery"
  },
  "dependencies": {
    "antd": "^6.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.160.0",
    "three": "^0.160.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  }
}
