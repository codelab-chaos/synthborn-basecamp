{
  "liveServer.settings.multiRootWorkspaceName": "synthborn-basecamp",
  "liveServer.settings.host": "0.0.0.0",
  "liveServer.settings.useLocalIp": true,
  "liveServer.settings.ignoreFiles": [
    ".vscode/**",
    "**/*.scss",
    "**/*.sass",
    "**/*.ts",
    "**/*.tsx",
    "node_modules/**",
    "tools/**",
    "_Assets/**",
    "apps/prefab-gallery/data/**",
    "apps/prefab-gallery/previews/**",
    "apps/prefab-gallery/node_modules/**"
  ],
  "git.ignoredRepositories": [
    "_mod-example-sourcecode",
    "_mod-example-sourcecode/*",
    "_mod-example-sourcecode/**"
  ],
  "files.watcherExclude": {
    "**/_mod-example-sourcecode/**": true
  },
  "search.exclude": {
    "_mod-example-sourcecode/**": true
  }
}
