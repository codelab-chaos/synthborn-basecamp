{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@basecamp/library/*": ["../library/*"]
    }
  },
  "include": ["src/**/*", "../library/recipe-query/**/*", "../library/basecamp-app-links.ts", "../library/basecamp-app-nav.tsx", "../library/basecamp-app-badge.tsx", "../library/basecamp-theme.ts", "../library/basecamp-shell.css"]
}
